{
  "name": "Ride",
  "type": "object",
  "properties": {
    "driver_email": {
      "type": "string",
      "description": "Email of the driver offering the ride"
    },
    "driver_name": {
      "type": "string",
      "description": "Name of the driver"
    },
    "pickup_location": {
      "type": "string",
      "description": "Pickup location name"
    },
    "pickup_lat": {
      "type": "number",
      "description": "Pickup latitude"
    },
    "pickup_lng": {
      "type": "number",
      "description": "Pickup longitude"
    },
    "dropoff_location": {
      "type": "string",
      "description": "Dropoff location name"
    },
    "dropoff_lat": {
      "type": "number",
      "description": "Dropoff latitude"
    },
    "dropoff_lng": {
      "type": "number",
      "description": "Dropoff longitude"
    },
    "departure_date": {
      "type": "string",
      "format": "date",
      "description": "Date of departure"
    },
    "departure_time": {
      "type": "string",
      "description": "Time of departure (HH:MM)"
    },
    "price_per_seat": {
      "type": "number",
      "description": "Price per seat in dollars"
    },
    "total_seats": {
      "type": "number",
      "description": "Total available seats"
    },
    "booked_seats": {
      "type": "number",
      "description": "Number of seats already booked",
      "default": 0
    },
    "vehicle_make": {
      "type": "string",
      "description": "Vehicle make/model"
    },
    "vehicle_color": {
      "type": "string",
      "description": "Vehicle color"
    },
    "vehicle_plate": {
      "type": "string",
      "description": "License plate number"
    },
    "notes": {
      "type": "string",
      "description": "Additional ride notes"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "cancelled"
      ],
      "default": "active"
    }
  },
  "required": [
    "driver_email",
    "driver_name",
    "pickup_location",
    "dropoff_location",
    "departure_date",
    "departure_time",
    "price_per_seat",
    "total_seats"
  ]
}