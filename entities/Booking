{
  "name": "Booking",
  "type": "object",
  "properties": {
    "ride_id": {
      "type": "string",
      "description": "ID of the booked ride"
    },
    "rider_email": {
      "type": "string",
      "description": "Email of the rider"
    },
    "rider_name": {
      "type": "string",
      "description": "Name of the rider"
    },
    "driver_email": {
      "type": "string",
      "description": "Email of the driver"
    },
    "seats_booked": {
      "type": "number",
      "description": "Number of seats booked",
      "default": 1
    },
    "total_price": {
      "type": "number",
      "description": "Total price for booking"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "cancelled",
        "completed"
      ],
      "default": "pending"
    },
    "pickup_location": {
      "type": "string"
    },
    "dropoff_location": {
      "type": "string"
    },
    "departure_date": {
      "type": "string",
      "format": "date"
    },
    "departure_time": {
      "type": "string"
    }
  },
  "required": [
    "ride_id",
    "rider_email",
    "rider_name",
    "driver_email",
    "seats_booked",
    "total_price"
  ]
}