{
  "name": "Review",
  "type": "object",
  "properties": {
    "ride_id": {
      "type": "string",
      "description": "Related ride ID"
    },
    "reviewer_email": {
      "type": "string",
      "description": "Email of the reviewer"
    },
    "reviewer_name": {
      "type": "string",
      "description": "Name of the reviewer"
    },
    "reviewee_email": {
      "type": "string",
      "description": "Email of the person being reviewed"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Rating 1-5"
    },
    "comment": {
      "type": "string",
      "description": "Review comment"
    }
  },
  "required": [
    "ride_id",
    "reviewer_email",
    "reviewee_email",
    "rating"
  ]
}